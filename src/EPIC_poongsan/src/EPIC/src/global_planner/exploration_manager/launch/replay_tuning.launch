<launch>
  <!-- ===================================================================
       EPIC 디버그/튜닝 전용 launch  (비행 없음, rosbag 재생 기반)

       목적: 실비행 rosbag을 재생해 EPIC만 돌리고, real.yaml 파라미터를
             바꿔가며 rviz로 프론티어/뷰포인트/경로가 나오는지 확인.

       재생할 EPIC 입력은 2개뿐:  /Odometry , /cloud_registered
       (TF/트리거/시각화는 이 launch가 직접 띄움 = 자기완결)

       띄우지 않는 것: FAST-LIO, livox, mavros, traj_server,
                       px4_ctrl_bridge, local_avoidance  (비행/제어 불필요)

       파라미터는 real.yaml 을 그대로 로드함(algorithm.xml 경유).
       real.yaml 수정 -> exploration_node 재시작(맵 초기화)하면 반영.
       실행 명령은 README / 대화 메모 참고 (rosbag 은 clock 플래그로 재생).
       =================================================================== -->

  <arg name="config_file" default="real.yaml"/>   <!-- 튜닝 대상 config (그대로 로드) -->
  <!-- odom/cloud 토픽은 config yaml 의 odometry_topic/cloud_topic 이 유일한 소스
       (모든 노드가 파라미터로 직접 읽음, remap 폐지). -->
  <arg name="rviz"        default="true"/>

  <!-- sim time: rosbag 을 clock 플래그로 재생할 때 필요. 노드보다 먼저 설정 -->
  <param name="/use_sim_time" value="true"/>

  <!-- TF: 재생은 /Odometry,/cloud_registered 만 하므로 TF는 여기서 publish.
       실비행 4_tf_odom_relay.sh 와 동일한 identity static TF 3개.
       bag frame: /Odometry=camera_init(child=body), /cloud_registered=camera_init.
       EPIC 의 frt/occ/pocc voxel 은 'world' 프레임 발행 -> camera_init->world 필수. -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="tf_camera_init_world"
        args="0 0 0 0 0 0 camera_init world"/>
  <node pkg="tf2_ros" type="static_transform_publisher" name="tf_odom_camera_init"
        args="0 0 0 0 0 0 odom camera_init"/>
  <node pkg="tf2_ros" type="static_transform_publisher" name="tf_body_base_link"
        args="0 0 0 0 0 0 body base_link"/>

  <!-- 1) EPIC 플래너 본체 = real.yaml 로드 (실비행과 동일 경로) -->
  <include file="$(find epic_planner)/launch/algorithm.xml">
    <arg name="config_file" value="$(arg config_file)"/>
  </include>

  <!-- 2) 트리거용 waypoint_generator : rviz '2D Nav Goal'(/move_base_simple/goal)
          -> /waypoint_generator/waypoints (FSM 트리거) -->
  <node pkg="waypoint_generator" name="waypoint_generator" type="waypoint_generator"
        output="screen">
    <remap from="~goal" to="/move_base_simple/goal"/>
    <remap from="~traj_start_trigger" to="/traj_start_trigger"/>
    <param name="waypoint_type" value="point"/>
  </node>

  <!-- 3) 드론 mesh 시각화 (제어와 무관, 순수 viz) -->
  <node pkg="odom_visualization" name="quad0_odom_visualization" type="odom_visualization"
        output="screen">
    <param name="color/a" value="1.0"/>
    <param name="color/r" value="0.0"/>
    <param name="color/g" value="1.0"/>
    <param name="color/b" value="1.0"/>
    <param name="covariance_scale" value="100.0"/>
    <param name="robot_scale" value="1.0"/>
    <param name="quadrotor_name" value="quad0"/>
    <param name="drone_id" value="0"/>
    <param name="mesh_resource" value="package://odom_visualization/meshes/yunque.dae"/>
  </node>

  <!-- 4) rviz (real.rviz, Fixed Frame=world) -->
  <group if="$(arg rviz)">
    <node name="rvizvisualisation" pkg="rviz" type="rviz" output="log"
          args="-d $(find epic_planner)/config/real.rviz"/>
  </group>

</launch>
